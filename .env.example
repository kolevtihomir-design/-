# ============================================================
# AI-Pokupki B2B Platform — Environment Variables
# ============================================================
# Копирай този файл като .env и попълни ключовете

# ── STRIPE (задължителен за плащания) ──────────────────────
# Регистрация: https://dashboard.stripe.com/register
# След регистрация: Developers → API Keys → Secret key
STRIPE_SECRET_KEY="sk_test_..."
# За webhook (stripe listen --forward-to localhost:3000/api/webhook):
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── EASYSHIP (безплатен — логистика/ставки) ─────────────────
# Регистрация: https://app.easyship.com/signup (без карта)
# След регистрация: Settings → API → Generate Token
EASYSHIP_API_KEY=""

# ── SERPAPI (100 безплатни търсения/месец — цени) ───────────
# Регистрация: https://serpapi.com/users/sign_up (без карта)
# След регистрация: Dashboard → Your Private API Key
SERPAPI_KEY=""

# ── HUGGINGFACE (30 000 безплатни req/месец — AI модел) ─────
# Регистрация: https://huggingface.co/join (без карта)
# След регистрация: Settings → Access Tokens → New token (Read)
HF_API_TOKEN=""

# ── APP URL (auto-inject при deploy) ────────────────────────
APP_URL="http://localhost:3000"
